<!DOCTYPE html>
<html lang="en">

<head>

<meta charset="UTF-8">

<meta name="viewport"
content="width=device-width, initial-scale=1.0">

<title>TEMPLE_DOMIC_EMMZY_TECH</title>

<link rel="stylesheet"
href="style.css">

</head>

<body>

<div class="background"></div>

<div class="container">

<h1 class="glow">
SYSTEM ONLINE
</h1>

<p class="subtitle">
Pairing System
</p>

<input
type="text"
id="number"
placeholder="Enter WhatsApp Number">

<button onclick="pairBot()">
CONNECT
</button>

<div id="result"></div>

</div>

<div class="admin-circle"
onclick="toggleAdmin()">
⚙
</div>

<div class="admin-panel"
id="adminPanel">

<h2>ADMIN PANEL</h2>

<input
type="password"
id="password"
placeholder="Enter Password">

<button onclick="loginAdmin()">
LOGIN
</button>

<div id="controls"
style="display:none;">

<input
type="text"
id="imgurl"
placeholder="Menu Image URL">

<button onclick="updateImage()">
UPDATE IMAGE
</button>

<button onclick="restartBot()">
RESTART BOT
</button>

</div>

</div>

<script src="app.js"></script>

</body>
</html>